---
import { ViewTransitions } from 'astro:transitions';
const {
  title = "Portfolio",
  path = "/",
  description = "Darrell Chew - Data Analyst & Analytics Engineer based in Melbourne, Australia.",
  canonicalPath = path,
  seoUrl,
  ogImage = "/profile.jpg",
  ogType = "website",
  twitterCard = "summary_large_image",
} = Astro.props;

const siteOrigin = (Astro.site?.toString() ?? "https://darrellchew.com").replace(/\/$/, "");
const toAbsoluteUrl = (value: string) => {
  if (!value) return siteOrigin;
  if (value.startsWith("http://") || value.startsWith("https://")) return value;
  return value.startsWith("/") ? `${siteOrigin}${value}` : `${siteOrigin}/${value}`;
};

const canonicalUrl = toAbsoluteUrl(seoUrl ?? canonicalPath);
const socialImageUrl = toAbsoluteUrl(ogImage);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta name="twitter:card" content={twitterCard} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImageUrl} />
  <title>{title}</title>
  <ViewTransitions />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/profile.jpg" />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />

  <!-- Apply theme before paint to prevent flash -->
  <script is:inline>
    (function () {
      var t = localStorage.getItem('dc-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <!-- Schema.org markup -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Darrell Chew",
      "jobTitle": "Data Analyst & Analytics Engineer",
      "url": "https://darrellchew.com",
      "image": "https://darrellchew.com/profile.jpg",
      "location": {
        "@type": "City",
        "name": "Melbourne",
        "addressCountry": "Australia"
      },
      "sameAs": [
        "https://github.com/djchew",
        "https://linkedin.com/in/darrell-chew"
      ]
    }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <!-- ── Top Navigation ── -->
  <nav class="top-nav" aria-label="Main">
    <a href="/" class="nav-logo">Darrell Chew</a>
    <div class="nav-links">
      <a href="/projects" class={`nav-link${path === "/projects" || path.startsWith("/projects/") ? " active" : ""}`}>
        Projects
        {(path === "/projects" || path.startsWith("/projects/")) && <span class="nav-dot">•</span>}
      </a>
      <a href="/resume" class={`nav-link${path === "/resume" ? " active" : ""}`}>
        Resume
        {path === "/resume" && <span class="nav-dot">•</span>}
      </a>
      <div class="nav-icons">
        <a href="https://github.com/djchew" target="_blank" rel="noopener" title="GitHub" aria-label="GitHub profile">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/darrell-chew" target="_blank" rel="noopener" title="LinkedIn" aria-label="LinkedIn profile">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <!-- ── Floating toolbar ── -->
  <div class="toolbar">
    <div class="settings-panel" id="settings-panel" hidden>
      <p class="settings-label">Appearance</p>
      <div class="theme-opts">

        <button class="theme-opt" data-t="light">
          <span class="swatch" style="background:#f5f3ee;border-color:#c8c4bb"></span>
          <span class="opt-body">
            <span class="opt-name">Light</span>
            <span class="opt-desc">Warm &amp; minimal</span>
          </span>
          <svg class="opt-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>

        <button class="theme-opt" data-t="dark">
          <span class="swatch" style="background:#0f1923;border-color:#1e3a55"></span>
          <span class="opt-body">
            <span class="opt-name">Dark</span>
            <span class="opt-desc">Easy on the eyes</span>
          </span>
          <svg class="opt-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>

        <button class="theme-opt" data-t="grey">
          <span class="swatch" style="background:#f0f0f0;border-color:#c0c0c0"></span>
          <span class="opt-body">
            <span class="opt-name">Grey</span>
            <span class="opt-desc">Clean &amp; neutral</span>
          </span>
          <svg class="opt-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>

      </div>
    </div>

    <div class="tool-btns">
      <a class="tool-btn" href="/Darrell%20Chew%20Resume.pdf" download="Darrell_Chew_Resume.pdf" title="Download Resume PDF" aria-label="Download Resume PDF">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </a>
      <button class="tool-btn" id="btn-settings" title="Appearance" aria-label="Appearance settings">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
        </svg>
      </button>
    </div>
  </div>

  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>

  <script>
    // ── Theme ──────────────────────────────────────────
    function applyTheme(t: string) {
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('dc-theme', t);
      document.querySelectorAll<HTMLElement>('.theme-opt').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.t === t);
      });
    }

    // ── Settings panel ─────────────────────────────────
    function initSettingsPanel() {
      const panel = document.getElementById('settings-panel')!;
      const btnSettings = document.getElementById('btn-settings')!;

      btnSettings.addEventListener('click', () => {
        panel.hidden = !panel.hidden;
      });

      document.addEventListener('mousedown', (e) => {
        if (!panel.hidden && !panel.contains(e.target as Node) && e.target !== btnSettings) {
          panel.hidden = true;
        }
      });

      document.querySelectorAll<HTMLElement>('.theme-opt').forEach(btn => {
        btn.addEventListener('click', () => applyTheme(btn.dataset.t!));
      });
    }

    // ── Scroll animations ──────────────────────────────
    function initAnimations() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
    }

    // ── Init on first load and after each page transition ──
    function init() {
      const theme = localStorage.getItem('dc-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      applyTheme(theme);
      initSettingsPanel();
      initAnimations();
    }

    document.addEventListener('astro:page-load', init);
  </script>
</body>
</html>

<style is:global>
  /* ── Reset ─────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
  h1 { font-family: 'Playfair Display', serif; }
  main { display: block; }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0.5rem;
    z-index: 1000;
    background: var(--accent);
    color: #fff;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .skip-link:focus-visible {
    left: 0.5rem;
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  /* ── Theme variables ────────────────────────────── */
  :root {
    --bg-page:    #f5f3ee;
    --bg-sidebar: #eae8e2;
    --bg-card:    #ffffff;
    --bd-main:    #dbd8cf;
    --bd-subtle:  #ebe8df;
    --bd-card:    #e5e3da;
    --bd-accent:  #b8d4e8;
    --tx-1:       #111111;
    --tx-2:       #444444;
    --tx-3:       #666666;
    --tx-muted:   #888888;
    --tx-subtle:  #999999;
    --accent:     #1e5f8e;
    --accent-bg:  #f0f7fd;
    --tag-bg:     #dbeafe;
    --tag-color:  #1e40af;
    --pill-bg:    #e5e3dc;
    --icon-bg:    #dbeafe;
    --icon-muted: #eceae3;
    --avatar-bg:  #1e5f8e;
    --avatar-fg:  #ffffff;
    --scrollbar:  #cccccc;
    --panel-bg:   #ffffff;
    --panel-bd:   #e0ddd6;
    --shadow:     rgba(0,0,0,0.08);
  }

  [data-theme="dark"] {
    --bg-page:    #0f1923;
    --bg-sidebar: #0b1828;
    --bg-card:    #112030;
    --bd-main:    #1e3a55;
    --bd-subtle:  #182d42;
    --bd-card:    #1e3a55;
    --bd-accent:  #1e4a70;
    --tx-1:       #e2e8f0;
    --tx-2:       #a8bac8;
    --tx-3:       #8a9fb5;
    --tx-muted:   #6b8099;
    --tx-subtle:  #5a7090;
    --accent:     #60b4f0;
    --accent-bg:  #0a2035;
    --tag-bg:     #0f2d4a;
    --tag-color:  #7ec8f4;
    --pill-bg:    #1a3355;
    --icon-bg:    #0f2d4a;
    --icon-muted: #1a2d40;
    --avatar-bg:  #1e4f7a;
    --avatar-fg:  #e2e8f0;
    --scrollbar:  #2a4a65;
    --panel-bg:   #112030;
    --panel-bd:   #1e3a55;
    --shadow:     rgba(0,0,0,0.45);
  }

  [data-theme="grey"] {
    --bg-page:    #f0f0f0;
    --bg-sidebar: #e4e4e4;
    --bg-card:    #ffffff;
    --bd-main:    #cccccc;
    --bd-subtle:  #d8d8d8;
    --bd-card:    #dddddd;
    --bd-accent:  #aabbcc;
    --tx-1:       #111111;
    --tx-2:       #444444;
    --tx-3:       #555555;
    --tx-muted:   #777777;
    --tx-subtle:  #888888;
    --accent:     #1e5f8e;
    --accent-bg:  #eef4fb;
    --tag-bg:     #d8e8f5;
    --tag-color:  #1e5f8e;
    --pill-bg:    #d8d8d8;
    --icon-bg:    #d8e8f5;
    --icon-muted: #e0e0e0;
    --avatar-bg:  #666666;
    --avatar-fg:  #ffffff;
    --scrollbar:  #bbbbbb;
    --panel-bg:   #ffffff;
    --panel-bd:   #d0d0d0;
    --shadow:     rgba(0,0,0,0.06);
  }

  /* ── Scroll animations ──────────────────────────── */
  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  [data-animate].in-view {
    opacity: 1;
    transform: none;
  }

  /* ── Top Nav ────────────────────────────────────── */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2.5rem;
    background: var(--bg-sidebar);
    border-bottom: 1px solid var(--bd-main);
    backdrop-filter: blur(8px);
  }

  .nav-logo {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--tx-1);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .nav-logo:hover { opacity: 0.75; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    position: relative;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--tx-2);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.15s;
  }

  .nav-link:hover { color: var(--tx-1); }

  .nav-link.active { color: var(--accent); }

  .nav-dot {
    font-size: 0.6rem;
    color: var(--accent);
    margin-left: 0.2rem;
  }

  .nav-icons {
    display: flex;
    gap: 0.75rem;
    margin-left: 0.5rem;
    border-left: 1px solid var(--bd-subtle);
    padding-left: 1.25rem;
  }

  .nav-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    color: var(--tx-2);
    transition: color 0.15s;
  }

  .nav-icons a:hover { color: var(--accent); }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Toolbar ────────────────────────────────────── */
  .toolbar {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    z-index: 200;
  }

  .settings-panel {
    background: var(--panel-bg);
    border: 1px solid var(--panel-bd);
    border-radius: 12px;
    padding: 1rem 1rem 0.75rem;
    box-shadow: 0 8px 32px var(--shadow);
    min-width: 210px;
  }

  .settings-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    margin-bottom: 0.6rem;
  }

  .theme-opts {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .theme-opt {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    padding: 0.5rem 0.6rem;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    color: var(--tx-1);
    text-align: left;
    transition: background 0.15s, border-color 0.15s;
  }

  .theme-opt:hover {
    background: var(--accent-bg);
    border-color: var(--bd-accent);
  }

  .theme-opt.active {
    background: var(--accent-bg);
    border-color: var(--accent);
  }

  .swatch {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid;
    flex-shrink: 0;
    display: block;
  }

  .opt-body { flex: 1; }

  .opt-name {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--tx-1);
  }

  .opt-desc {
    display: block;
    font-size: 0.68rem;
    color: var(--tx-muted);
    line-height: 1.3;
  }

  .opt-check {
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .theme-opt.active .opt-check { opacity: 1; }

  .tool-btns {
    display: flex;
    gap: 0.4rem;
  }

  .tool-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--panel-bg);
    border: 1px solid var(--panel-bd);
    color: var(--tx-2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px var(--shadow);
    transition: background 0.15s, color 0.15s, transform 0.1s, border-color 0.15s;
  }

  .tool-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: scale(1.06);
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 600px) {
    .top-nav {
      padding: 0.75rem 1rem;
    }
    .nav-links {
      gap: 1rem;
    }
    .nav-icons {
      padding-left: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .settings-panel {
      right: 1rem;
      left: 1rem;
      min-width: unset;
      width: calc(100vw - 2rem);
    }
  }

  /* ── Page transitions ───────────────────────────── */
  @keyframes slide-in {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-out {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-40px); }
  }

  ::view-transition-old(root) {
    animation: 280ms ease both slide-out;
  }
  ::view-transition-new(root) {
    animation: 280ms ease both slide-in;
  }

  /* ── Print ──────────────────────────────────────── */
  @media print {
    .top-nav { display: none !important; }
    .toolbar { display: none !important; }
    [data-animate] { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    [data-animate] {
      opacity: 1 !important;
      transform: none !important;
    }
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none !important;
    }
  }
</style>
