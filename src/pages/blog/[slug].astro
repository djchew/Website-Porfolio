---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../../data/resume.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: posts[i - 1] ?? null,
      next: posts[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { name } = resume;
const { Content } = await post.render();
const pageDescription = post.data.description;
const canonicalPath = `/blog/${post.slug}`;
---

<Layout
  title={`${post.data.title} - ${name}`}
  path="/blog"
  canonicalPath={canonicalPath}
  description={pageDescription}
>
  <div class="blog-detail">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/blog">Blog</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{post.data.title}</span>
    </nav>

    <div class="content-wrap">

      <!-- HEADER -->
      <header class="post-header" data-animate>
        <div class="post-meta">
          <time datetime={post.data.date} class="post-date">
            {new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          {post.data.readTime && <span class="read-time">{post.data.readTime}</span>}
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- CONTENT -->
      <article class="prose" data-animate>
        <Content />
      </article>

      <!-- POST NAVIGATION -->
      <nav class="post-nav" aria-label="Post navigation" data-animate>
        {prev
          ? <a href={`/blog/${prev.slug}`} class="post-nav-btn prev">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
              </svg>
              <div class="post-nav-text">
                <span class="post-nav-label">Previous</span>
                <span class="post-nav-name">{prev.data.title}</span>
              </div>
            </a>
          : <div />
        }
        <a href="/blog" class="post-nav-all">All Posts</a>
        {next
          ? <a href={`/blog/${next.slug}`} class="post-nav-btn next">
              <div class="post-nav-text">
                <span class="post-nav-label">Next</span>
                <span class="post-nav-name">{next.data.title}</span>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          : <div />
        }
      </nav>

    </div>
  </div>
</Layout>

<style>
  .blog-detail {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Breadcrumb ──────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0 1rem 2rem;
    font-size: 0.82rem;
    color: var(--tx-2);
    margin: 1.5rem 0 0 0;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .breadcrumb a:hover {
    opacity: 0.75;
  }

  .breadcrumb span {
    color: var(--tx-muted);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--tx-2);
    font-weight: 500;
  }

  /* ── Content wrap ────────────────────────────────── */
  .content-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 2rem 5rem;
    overflow-x: hidden;
    background-image: var(--grad-mesh);
    background-attachment: fixed;
  }

  /* ── Post header ─────────────────────────────────── */
  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--tx-muted);
    font-weight: 500;
  }

  .read-time {
    font-size: 0.75rem;
    color: var(--tx-subtle);
    padding: 0.2rem 0.6rem;
    background: var(--pill-bg);
    border-radius: 999px;
  }

  .post-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.75rem;
    background: var(--grad-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-description {
    font-size: 1rem;
    color: var(--tx-2);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  /* ── Prose ───────────────────────────────────────── */
  .prose {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--tx-2);
    border-top: 1px solid var(--bd-subtle);
    padding-top: 2rem;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 1.75rem 0 0.6rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(code) {
    font-size: 0.85em;
    background: var(--icon-bg);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--bg-sidebar);
    border: 1px solid var(--bd-main);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--tx-2);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--tx-muted);
    font-style: italic;
    margin: 1.25rem 0;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--tx-1);
  }

  .prose :global(em) {
    font-style: italic;
  }

  /* ── Post Navigation ─────────────────────────────── */
  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--bd-subtle);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: start;
  }

  .post-nav-btn {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .post-nav-btn:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateY(-2px);
  }

  .post-nav-btn.prev {
    align-items: flex-start;
    grid-column: 1;
    flex-direction: row;
  }

  .post-nav-btn.next {
    align-items: flex-end;
    grid-column: 3;
    flex-direction: row-reverse;
  }

  .post-nav-btn svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .post-nav-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .post-nav-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tx-subtle);
  }

  .post-nav-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--tx-1);
    line-height: 1.4;
  }

  .post-nav-all {
    padding: 1.25rem;
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .post-nav-all:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateY(-2px);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 600px) {
    .breadcrumb { padding-left: 1rem; gap: 0.25rem; }
    .breadcrumb span { display: none; }
    .breadcrumb a:not(:last-child)::after { content: " /"; margin-right: 0.3rem; color: var(--tx-muted); }
    .content-wrap { padding: 2rem 1.25rem 3rem; }
    .post-title { font-size: 1.4rem; }
    .prose { font-size: 0.9rem; }
    .post-nav { grid-template-columns: 1fr; gap: 0.75rem; }
    .post-nav-btn, .post-nav-all { grid-column: auto; }
  }
</style>
