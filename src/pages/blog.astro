---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../data/resume.json';

const blogPosts = await getCollection('blog');
blogPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const { name } = resume;
const pageDescription = "Thoughts on data quality, dashboards, pipelines, and building data products.";
const canonicalPath = "/blog";
---

<Layout
  title={`Blog - ${name}`}
  path="/blog"
  canonicalPath={canonicalPath}
  description={pageDescription}
>
  <div class="blog-page">
    <header class="blog-header" data-animate>
      <h1>Blog</h1>
      <p>Thoughts on data engineering, analytics, and building products that people actually use.</p>
    </header>

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">Blog</span>
    </nav>

    <div class="blog-list">
      {blogPosts.map((post) => (
        <article class="blog-card" data-animate>
          <div class="card-header">
            <time datetime={post.data.date} class="post-date">
              {new Date(post.data.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            {post.data.readTime && <span class="read-time">{post.data.readTime}</span>}
          </div>
          <h2 class="post-title">
            <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          </h2>
          <p class="post-description">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          <a href={`/blog/${post.slug}`} class="read-more">
            Read more
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
  .blog-page {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Breadcrumb ──────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0 2rem 2rem;
    font-size: 0.82rem;
    color: var(--tx-2);
    max-width: 800px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .breadcrumb a:hover {
    opacity: 0.75;
  }

  .breadcrumb span {
    color: var(--tx-muted);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--tx-2);
    font-weight: 500;
  }

  /* ── Blog Header ─────────────────────────────────── */
  .blog-header {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 2rem 3rem;
    background-image: var(--grad-mesh);
    background-attachment: fixed;
  }

  .blog-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    background: var(--grad-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-header p {
    font-size: 1rem;
    color: var(--tx-2);
    line-height: 1.6;
  }

  /* ── Blog List ───────────────────────────────────── */
  .blog-list {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* ── Blog Card ───────────────────────────────────── */
  .blog-card {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--bd-subtle);
    transition: all 0.15s;
  }

  .blog-card:first-child {
    padding-top: 0;
  }

  .blog-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .blog-card:hover .post-title a {
    color: var(--accent);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.82rem;
    color: var(--tx-muted);
    font-weight: 500;
  }

  .read-time {
    font-size: 0.75rem;
    color: var(--tx-subtle);
    padding: 0.2rem 0.6rem;
    background: var(--pill-bg);
    border-radius: 999px;
  }

  .post-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0.5rem 0 0.6rem;
    line-height: 1.4;
  }

  .post-title a {
    color: var(--tx-1);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-title a:hover {
    color: var(--accent);
  }

  .post-description {
    font-size: 0.95rem;
    color: var(--tx-2);
    line-height: 1.6;
    margin: 0.5rem 0 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.15s, opacity 0.15s;
  }

  .read-more:hover {
    gap: 0.5rem;
    opacity: 0.85;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 600px) {
    .blog-header {
      padding: 1.5rem 1.25rem 2rem;
    }

    .blog-header h1 {
      font-size: 1.75rem;
    }

    .blog-header p {
      font-size: 0.9rem;
    }

    .blog-list {
      padding: 0 1.25rem 3rem;
    }

    .post-title {
      font-size: 1.15rem;
    }

    .breadcrumb {
      padding: 0.75rem 0 1.5rem 1rem;
    }
  }
</style>
