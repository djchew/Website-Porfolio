---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../../data/resume.json';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  projects.sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));
  return projects.map((proj, i) => ({
    params: { slug: proj.slug },
    props: {
      proj,
      prev: projects[i + 1] ?? null,
      next: projects[i - 1] ?? null,
    },
  }));
}

const { proj, prev, next } = Astro.props;
const { name } = resume;
const { Content } = await proj.render();
const projectImage = proj.data.seoImage ?? proj.data.image ?? proj.data.images?.[0] ?? "/profile.jpg";
const pageDescription = proj.data.description;
const canonicalPath = `/projects/${proj.slug}`;
---

<Layout
  title={`${proj.data.name} - ${name}`}
  path="/projects"
  canonicalPath={canonicalPath}
  description={pageDescription}
  ogImage={projectImage}
  ogType="article"
>
  <div class="detail-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href="/projects">Projects</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{proj.data.name}</span>
    </nav>

    <div class="content-wrap">

      <!-- LIGHTBOX -->
      <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Project image preview">
        <button class="lightbox-close" id="lightbox-close" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      </div>

      <!-- HERO / GALLERY -->
      {(() => {
        const imgs = proj.data.images ?? (proj.data.image ? [proj.data.image] : []);
        if (imgs.length === 0) return null;
        if (imgs.length === 1) return (
          <div class="hero-thumb" data-animate>
            <img src={imgs[0]} alt={proj.data.name} class="zoomable" data-src={imgs[0]} loading="lazy" decoding="async" width="1280" height="720" />
          </div>
        );
        return (
          <div class="gallery" data-animate>
            <div class="gallery-main">
              <img id="gallery-main-img" src={imgs[0]} alt={proj.data.name} class="zoomable" data-src={imgs[0]} loading="lazy" decoding="async" width="1280" height="720" />
            </div>
            <div class="gallery-thumbs">
              {imgs.map((src, i) => (
                <button type="button" class={`gallery-thumb${i === 0 ? ' active' : ''}`} data-src={src} aria-label={`View image ${i + 1}`}>
                  <img src={src} alt={`${proj.data.name} screenshot ${i + 1}`} loading="lazy" decoding="async" width="160" height="104" />
                </button>
              ))}
            </div>
          </div>
        );
      })()}

      <!-- HEADER -->
      <header class="proj-header" data-animate>
        <div class="proj-meta">
          {proj.data.date && <span class="proj-date">{proj.data.date}</span>}
          {proj.data.role && <span class="proj-date">{proj.data.role}</span>}
          <div class="proj-tags">
            {proj.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <h1 class="proj-title">{proj.data.name}</h1>
        <p class="proj-desc">{proj.data.description}</p>
        <div class="proj-ctas">
          <a href={proj.data.link} target="_blank" rel="noopener" class="github-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
          {proj.data.liveDemo && (
            <a href={proj.data.liveDemo} target="_blank" rel="noopener" class="github-link">
              Live Demo
            </a>
          )}
          {proj.data.caseStudy && (
            <a href={proj.data.caseStudy} target="_blank" rel="noopener" class="github-link">
              Case Study
            </a>
          )}
        </div>
      </header>

      {proj.data.outcomes && proj.data.outcomes.length > 0 && (
        <section class="project-outcomes" data-animate>
          <h2 class="journal-heading">Key outcomes</h2>
          <ul>
            {proj.data.outcomes.map((outcome) => <li>{outcome}</li>)}
          </ul>
        </section>
      )}

      <!-- JOURNAL -->
      <article class="journal" data-animate>
        <h2 class="journal-heading">Journal</h2>
        <div class="prose">
          <Content />
        </div>
      </article>

      <!-- PROJECT NAVIGATION -->
      <nav class="proj-nav" aria-label="Project navigation" data-animate>
        {prev
          ? <a href={`/projects/${prev.slug}`} class="proj-nav-btn prev">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
              </svg>
              <div class="proj-nav-text">
                <span class="proj-nav-label">Previous</span>
                <span class="proj-nav-name">{prev.data.name}</span>
              </div>
            </a>
          : <div />
        }
        <a href="/projects" class="proj-nav-all">All Projects</a>
        {next
          ? <a href={`/projects/${next.slug}`} class="proj-nav-btn next">
              <div class="proj-nav-text">
                <span class="proj-nav-label">Next</span>
                <span class="proj-nav-name">{next.data.name}</span>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          : <div />
        }
      </nav>

    </div>
  </div>
</Layout>

<style>
  .detail-page {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Breadcrumb ──────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0 1rem 2.5rem;
    font-size: 0.82rem;
    color: var(--tx-2);
    margin: 1.5rem 0 0 0;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .breadcrumb a:hover {
    opacity: 0.75;
  }

  .breadcrumb span {
    color: var(--tx-muted);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--tx-2);
    font-weight: 500;
  }

  /* ── Content wrap ────────────────────────────────── */
  .content-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    overflow-x: hidden;
  }

  /* ── Hero thumbnail ──────────────────────────────── */
  .hero-thumb {
    width: calc(100% + 28rem);
    margin-left: -14rem;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    border: 1px solid var(--bd-card);
  }

  .hero-thumb img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Lightbox ────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-img {
    max-width: 92vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    transition: transform 0.25s ease;
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }

  .lightbox-close:hover { background: rgba(255,255,255,0.2); }

  .zoomable {
    cursor: zoom-in;
    transition: opacity 0.15s;
  }

  .zoomable:hover {
    opacity: 0.93;
  }

  /* ── Gallery ─────────────────────────────────────── */
  .gallery {
    width: calc(100% + 28rem);
    margin-left: -14rem;
    margin-bottom: 2.5rem;
  }

  .gallery-main {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--bd-card);
    margin-bottom: 0.75rem;
    background: var(--icon-bg);
  }

  .gallery-main img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.2s ease;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .gallery-thumb {
    width: 80px;
    height: 52px;
    border-radius: 7px;
    overflow: hidden;
    border: 2px solid var(--bd-card);
    background: none;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.15s, opacity 0.15s, transform 0.15s;
    opacity: 0.75;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-thumb:hover {
    opacity: 1;
    transform: scale(1.03);
  }

  .gallery-thumb.active {
    border-color: var(--accent);
    opacity: 1;
    box-shadow: 0 0 0 2px var(--accent);
  }

  /* ── Project header ──────────────────────────────── */
  .proj-header {
    margin-bottom: 2.5rem;
  }

  .proj-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .proj-date {
    font-size: 0.72rem;
    color: var(--tx-muted);
    padding: 0.15rem 0.55rem;
    background: var(--pill-bg);
    border-radius: 999px;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .proj-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--tx-1);
    line-height: 1.2;
    margin-bottom: 0.6rem;
  }

  .proj-desc {
    font-size: 0.95rem;
    color: var(--tx-2);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--bd-accent);
    border-radius: 8px;
    background: var(--accent-bg);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .proj-ctas {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-outcomes {
    border-top: 1px solid var(--bd-subtle);
    padding-top: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .project-outcomes ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--tx-2);
  }

  .project-outcomes li {
    font-size: 0.86rem;
    line-height: 1.6;
    margin-bottom: 0.35rem;
  }

  .github-link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* ── Journal ─────────────────────────────────────── */
  .journal {
    border-top: 1px solid var(--bd-subtle);
    padding-top: 2rem;
  }

  .journal-heading {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    margin-bottom: 1.5rem;
  }

  /* ── Prose ───────────────────────────────────────── */
  .prose {
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--tx-2);
  }

  .prose :global(h2) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) { margin-bottom: 1.1rem; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }

  .prose :global(li) { margin-bottom: 0.35rem; }

  .prose :global(code) {
    font-size: 0.85em;
    background: var(--icon-bg);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--bg-sidebar);
    border: 1px solid var(--bd-main);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.1rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--tx-2);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--tx-muted);
    font-style: italic;
    margin: 1.1rem 0;
  }

  /* ── Project Navigation ──────────────────────────── */
  .proj-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--bd-subtle);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: start;
  }

  .proj-nav-btn {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .proj-nav-btn:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateY(-2px);
  }

  .proj-nav-btn.prev {
    align-items: flex-start;
    grid-column: 1;
    flex-direction: row;
  }

  .proj-nav-btn.next {
    align-items: flex-end;
    grid-column: 3;
    flex-direction: row-reverse;
  }

  .proj-nav-btn svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .proj-nav-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .proj-nav-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tx-subtle);
  }

  .proj-nav-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--tx-1);
    line-height: 1.4;
  }

  .proj-nav-all {
    padding: 1.25rem;
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  .proj-nav-all:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateY(-2px);
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 780px) {
    .hero-thumb {
      width: 100%;
      margin-left: 0;
    }
    .gallery {
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 600px) {
    .breadcrumb { padding-left: 1rem; gap: 0.25rem; }
    .breadcrumb span { display: none; }
    .breadcrumb a:not(:last-child)::after { content: " /"; margin-right: 0.3rem; color: var(--tx-muted); }
    .content-wrap { padding: 2rem 1.25rem 3rem; }
    .proj-title { font-size: 1.5rem; }
    .gallery-thumb { width: 60px; height: 40px; }
    .proj-nav { grid-template-columns: 1fr; gap: 0.75rem; }
    .proj-nav-btn, .proj-nav-all { grid-column: auto; }
  }
</style>

<script>
  const previousController = (window as any).__projectDetailController as AbortController | undefined;
  previousController?.abort();
  const controller = new AbortController();
  (window as any).__projectDetailController = controller;
  const { signal } = controller;

  document.addEventListener('astro:page-load', () => {
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return; // No images on this page

    const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.getElementById('lightbox-close') as HTMLButtonElement;
    let previousFocus: HTMLElement | null = null;

    // ── Gallery thumb switching ──
    document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!mainImg) return;
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = btn.dataset.src!;
          mainImg.dataset.src = btn.dataset.src!;
          mainImg.style.opacity = '1';
        }, 150);
        document.querySelectorAll('.gallery-thumb').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      }, { signal });
    });

    // ── Lightbox open ──
    function openLightbox(src: string, alt: string) {
      previousFocus = document.activeElement as HTMLElement | null;
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lightboxClose?.focus();
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (previousFocus) previousFocus.focus();
    }

    document.querySelectorAll<HTMLImageElement>('.zoomable').forEach(img => {
      img.addEventListener('click', () => openLightbox(img.dataset.src ?? img.src, img.alt), { signal });
    });

    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox, { signal });
    }
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); }, { signal });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'Tab' && lightbox.classList.contains('open')) {
        const focusables = lightbox.querySelectorAll<HTMLElement>('button, [href], [tabindex]:not([tabindex="-1"])');
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }, { signal });
  }, { signal });
</script>
