---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../../data/resume.json';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(proj => ({
    params: { slug: proj.slug },
    props: { proj },
  }));
}

const { proj } = Astro.props;
const { name } = resume;
const { Content } = await proj.render();
---

<Layout title={`${proj.data.name} – ${name}`} path="/projects">
  <div class="detail-page">

    <a href="/projects" class="back-button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
      </svg>
      Back to projects
    </a>

    <div class="content-wrap">

      <!-- LIGHTBOX -->
      <div class="lightbox" id="lightbox" aria-hidden="true">
        <button class="lightbox-close" id="lightbox-close" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      </div>

      <!-- HERO / GALLERY -->
      {(() => {
        const imgs = proj.data.images ?? (proj.data.image ? [proj.data.image] : []);
        if (imgs.length === 0) return null;
        if (imgs.length === 1) return (
          <div class="hero-thumb" data-animate>
            <img src={imgs[0]} alt={proj.data.name} class="zoomable" data-src={imgs[0]} />
          </div>
        );
        return (
          <div class="gallery" data-animate>
            <div class="gallery-main">
              <img id="gallery-main-img" src={imgs[0]} alt={proj.data.name} class="zoomable" data-src={imgs[0]} />
            </div>
            <div class="gallery-thumbs">
              {imgs.map((src, i) => (
                <button class={`gallery-thumb${i === 0 ? ' active' : ''}`} data-src={src} aria-label={`View image ${i + 1}`}>
                  <img src={src} alt={`${proj.data.name} screenshot ${i + 1}`} />
                </button>
              ))}
            </div>
          </div>
        );
      })()}

      <!-- HEADER -->
      <header class="proj-header" data-animate>
        <div class="proj-meta">
          {proj.data.date && <span class="proj-date">{proj.data.date}</span>}
          <div class="proj-tags">
            {proj.data.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <h1 class="proj-title">{proj.data.name}</h1>
        <p class="proj-desc">{proj.data.description}</p>
        <a href={proj.data.link} target="_blank" rel="noopener" class="github-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </header>

      <!-- JOURNAL -->
      <article class="journal" data-animate>
        <h2 class="journal-heading">Journal</h2>
        <div class="prose">
          <Content />
        </div>
      </article>

    </div>
  </div>
</Layout>

<style>
  .detail-page {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    margin: 1.5rem 0 0 2.5rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--bd-subtle);
    border-radius: 8px;
    background: transparent;
    transition: background 0.15s, border-color 0.15s;
  }

  .back-button:hover {
    background: var(--accent-bg);
    border-color: var(--accent);
  }

  /* ── Content wrap ────────────────────────────────── */
  .content-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  /* ── Hero thumbnail ──────────────────────────────── */
  .hero-thumb {
    width: calc(100% + 28rem);
    margin-left: -14rem;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    border: 1px solid var(--bd-card);
  }

  .hero-thumb img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Lightbox ────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-img {
    max-width: 92vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    transition: transform 0.25s ease;
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }

  .lightbox-close:hover { background: rgba(255,255,255,0.2); }

  .zoomable {
    cursor: zoom-in;
  }

  /* ── Gallery ─────────────────────────────────────── */
  .gallery {
    width: calc(100% + 28rem);
    margin-left: -14rem;
    margin-bottom: 2.5rem;
  }

  .gallery-main {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--bd-card);
    margin-bottom: 0.75rem;
    background: var(--icon-bg);
  }

  .gallery-main img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.2s ease;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .gallery-thumb {
    width: 80px;
    height: 52px;
    border-radius: 7px;
    overflow: hidden;
    border: 2px solid var(--bd-card);
    background: none;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.15s, opacity 0.15s;
    opacity: 0.65;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-thumb:hover { opacity: 0.85; }
  .gallery-thumb.active { border-color: var(--accent); opacity: 1; }

  /* ── Project header ──────────────────────────────── */
  .proj-header {
    margin-bottom: 2.5rem;
  }

  .proj-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .proj-date {
    font-size: 0.72rem;
    color: var(--tx-muted);
    padding: 0.15rem 0.55rem;
    background: var(--pill-bg);
    border-radius: 999px;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .proj-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--tx-1);
    line-height: 1.2;
    margin-bottom: 0.6rem;
  }

  .proj-desc {
    font-size: 0.95rem;
    color: var(--tx-2);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--bd-accent);
    border-radius: 8px;
    background: var(--accent-bg);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .github-link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* ── Journal ─────────────────────────────────────── */
  .journal {
    border-top: 1px solid var(--bd-main);
    padding-top: 2rem;
  }

  .journal-heading {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    margin-bottom: 1.5rem;
  }

  /* ── Prose ───────────────────────────────────────── */
  .prose {
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--tx-2);
  }

  .prose :global(h2) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tx-1);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) { margin-bottom: 1.1rem; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }

  .prose :global(li) { margin-bottom: 0.35rem; }

  .prose :global(code) {
    font-size: 0.85em;
    background: var(--icon-bg);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--bg-sidebar);
    border: 1px solid var(--bd-main);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.1rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--tx-2);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--tx-muted);
    font-style: italic;
    margin: 1.1rem 0;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 780px) {
    .hero-thumb {
      width: 100%;
      margin-left: 0;
    }
    .gallery {
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 600px) {
    .back-button { margin-left: 1rem; }
    .content-wrap { padding: 2rem 1.25rem 3rem; }
    .proj-title { font-size: 1.5rem; }
    .gallery-thumb { width: 60px; height: 40px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return; // No images on this page

    const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.getElementById('lightbox-close') as HTMLButtonElement;

    // ── Gallery thumb switching ──
    document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!mainImg) return;
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = btn.dataset.src!;
          mainImg.dataset.src = btn.dataset.src!;
          mainImg.style.opacity = '1';
        }, 150);
        document.querySelectorAll('.gallery-thumb').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    // ── Lightbox open ──
    function openLightbox(src: string, alt: string) {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLImageElement>('.zoomable').forEach(img => {
      img.addEventListener('click', () => openLightbox(img.dataset.src ?? img.src, img.alt));
    });

    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox);
    }
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  });
</script>
