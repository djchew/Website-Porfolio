---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../data/resume.json';

const { name } = resume;
const projects = await getCollection('projects');
projects.sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));
const pageDescription = "Portfolio projects by Darrell Chew covering analytics engineering, data pipelines, dashboards, and full-stack data products.";
---

<Layout
  title={`Projects - ${name}`}
  path="/projects"
  canonicalPath="/projects"
  description={pageDescription}
  ogType="website"
>
  <div class="projects-page">

    <!-- HEADER -->
    <header class="page-header" data-animate>
      <h1 class="page-title">Projects</h1>
      <p class="page-subtitle">End-to-end data projects — pipelines, dashboards, and analysis</p>
    </header>

    <!-- GRID -->
    <section class="grid">
      {projects.map((proj, i) => (
        <a
          class="card"
          href={`/projects/${proj.slug}`}
          data-animate
          style={`transition-delay:${i * 90}ms`}
        >
          <div class="card-thumb">
            {(proj.data.image ?? proj.data.images?.[0])
              ? <img src={proj.data.image ?? proj.data.images?.[0]} alt={proj.data.name} loading="lazy" decoding="async" width="1280" height="720" />
              : <div class="card-thumb-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
            }
          </div>
          <div class="card-body">
            <div class="card-meta">
              {proj.data.date && <span class="meta-pill">{proj.data.date}</span>}
              {proj.data.role && <span class="meta-pill">{proj.data.role}</span>}
            </div>
            <h2 class="card-name">{proj.data.name}</h2>
            <p class="card-desc">{proj.data.description}</p>
            {proj.data.outcomes?.[0] && (
              <p class="card-outcome">{proj.data.outcomes[0]}</p>
            )}
            <div class="card-tags">
              {proj.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <span class="card-link">
              Read more
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </span>
          </div>
        </a>
      ))}

      <!-- CTA Card -->
      <div class="card cta-card" data-animate style={`transition-delay:${projects.length * 90}ms`}>
        <div class="card-body cta-body">
          <p class="cta-eyebrow">Open to work</p>
          <h2 class="cta-heading">Let's build something together</h2>
          <p class="cta-sub">Open to full-time and contract roles in Melbourne or remote.</p>
          <div class="cta-actions">
            <a class="cta-btn primary" href="https://linkedin.com/in/darrell-chew" target="_blank" rel="noopener" aria-label="Connect on LinkedIn">LinkedIn</a>
            <a class="cta-btn secondary" id="cta-email" href="#">Email me</a>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .projects-page {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Page header ─────────────────────────────────── */
  .page-header {
    padding: 3rem 2.5rem 1.5rem;
    border-bottom: 1px solid var(--bd-subtle);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--tx-1);
    margin-bottom: 0.35rem;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--tx-muted);
  }

  /* ── Grid ────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
    padding: 0 2.5rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Card ────────────────────────────────────────── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
  }

  .card:not(.placeholder):hover {
    box-shadow: 0 6px 24px var(--shadow);
    border-color: var(--bd-accent);
    transform: translateY(-3px);
  }

  .placeholder {
    border-style: dashed;
    background: transparent;
    cursor: default;
  }

  /* ── Thumbnail ───────────────────────────────────── */
  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--icon-bg);
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .card-thumb img { transform: scale(1.04); }

  .card-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    background: var(--icon-bg);
  }

  .card-thumb-placeholder.muted {
    color: var(--tx-muted);
    background: var(--icon-muted);
  }

  /* ── Card body ───────────────────────────────────── */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .meta-pill {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--pill-bg);
    color: var(--tx-muted);
  }

  .card-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tx-1);
  }

  .card-name.muted { color: var(--tx-muted); }

  .card-desc {
    font-size: 0.82rem;
    color: var(--tx-3);
    line-height: 1.6;
    flex: 1;
  }

  .card-outcome {
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--tx-2);
    border-left: 2px solid var(--bd-accent);
    padding-left: 0.5rem;
  }

  .card-desc.muted { color: var(--tx-subtle); }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  /* ── CTA Card ──────────────────────────────────────── */
  .cta-card {
    background: transparent;
    border: 2px dashed var(--bd-card);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
  }

  .cta-body {
    padding: 2rem;
    text-align: center;
    gap: 1rem;
  }

  .cta-eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    margin-bottom: 0.5rem;
  }

  .cta-heading {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--tx-1);
    font-family: 'Playfair Display', serif;
    margin-bottom: 0.75rem;
  }

  .cta-sub {
    font-size: 0.85rem;
    color: var(--tx-3);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cta-btn {
    padding: 0.65rem 1.25rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
    border: 1px solid;
    display: inline-block;
    text-align: center;
  }

  .cta-btn.primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .cta-btn.primary:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .cta-btn.secondary {
    background: transparent;
    color: var(--accent);
    border-color: var(--accent);
  }

  .cta-btn.secondary:hover {
    background: var(--accent-bg);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 600px) {
    .page-header { padding: 2rem 1.25rem 1.25rem; }
    .grid     { padding: 0 1.25rem 2rem; grid-template-columns: 1fr; }
    .cta-heading { font-size: 1.15rem; }
    .cta-actions { flex-direction: column; }
    .cta-btn { width: 100%; }
  }

  /* ── Print ───────────────────────────────────────── */
  @media print {
    :root { --bg-page: #fff; --bg-card: #fff; --tx-1: #000; --tx-3: #333; }
    .card:hover { transform: none; box-shadow: none; }
    @page { margin: 1.5cm; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const u = 'darrellchew';
    const d = 'hotmail.com';
    const link = document.getElementById('cta-email') as HTMLAnchorElement;
    if (link) link.href = 'mailto:' + u + '@' + d;
  });
</script>
