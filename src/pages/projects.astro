---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../data/resume.json';

const { name } = resume;
const projects = await getCollection('projects');
projects.sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));
---

<Layout title={`Projects – ${name}`} path="/projects">
  <div class="projects-page">

    <!-- HEADER -->
    <header class="page-header" data-animate>
      <h1 class="page-title">Projects</h1>
      <p class="page-subtitle">End-to-end data projects — pipelines, dashboards, and analysis</p>
    </header>

    <!-- GRID -->
    <section class="grid">
      {projects.map((proj, i) => (
        <a
          class="card"
          href={`/projects/${proj.slug}`}
          data-animate
          style={`transition-delay:${i * 90}ms`}
        >
          <div class="card-thumb">
            {(proj.data.image ?? proj.data.images?.[0])
              ? <img src={proj.data.image ?? proj.data.images?.[0]} alt={proj.data.name} />
              : <div class="card-thumb-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
            }
          </div>
          <div class="card-body">
            <h2 class="card-name">{proj.data.name}</h2>
            <p class="card-desc">{proj.data.description}</p>
            <div class="card-tags">
              {proj.data.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <span class="card-link">
              Read more
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </span>
          </div>
        </a>
      ))}

      <!-- Placeholder -->
      <div class="card placeholder" data-animate style={`transition-delay:${projects.length * 90}ms`}>
        <div class="card-thumb card-thumb-placeholder muted">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
        </div>
        <div class="card-body">
          <h2 class="card-name muted">More coming soon</h2>
          <p class="card-desc muted">Check back soon for new projects.</p>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .projects-page {
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Page header ─────────────────────────────────── */
  .page-header {
    padding: 3rem 2.5rem 1.5rem;
    border-bottom: 1px solid var(--bd-main);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--tx-1);
    margin-bottom: 0.35rem;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--tx-muted);
  }

  /* ── Grid ────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    padding: 0 2.5rem 3rem;
  }

  /* ── Card ────────────────────────────────────────── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
  }

  .card:not(.placeholder):hover {
    box-shadow: 0 6px 24px var(--shadow);
    border-color: var(--bd-accent);
    transform: translateY(-3px);
  }

  .placeholder {
    border-style: dashed;
    background: transparent;
    cursor: default;
  }

  /* ── Thumbnail ───────────────────────────────────── */
  .card-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--icon-bg);
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .card:hover .card-thumb img { transform: scale(1.04); }

  .card-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    background: var(--icon-bg);
  }

  .card-thumb-placeholder.muted {
    color: var(--tx-muted);
    background: var(--icon-muted);
  }

  /* ── Card body ───────────────────────────────────── */
  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tx-1);
  }

  .card-name.muted { color: var(--tx-muted); }

  .card-desc {
    font-size: 0.82rem;
    color: var(--tx-3);
    line-height: 1.6;
    flex: 1;
  }

  .card-desc.muted { color: var(--tx-subtle); }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 600px) {
    .page-header { padding: 2rem 1.25rem 1.25rem; }
    .grid     { padding: 0 1.25rem 2rem; grid-template-columns: 1fr; }
  }

  /* ── Print ───────────────────────────────────────── */
  @media print {
    :root { --bg-page: #fff; --bg-card: #fff; --tx-1: #000; --tx-3: #333; }
    .card:hover { transform: none; box-shadow: none; }
    @page { margin: 1.5cm; }
  }
</style>
