---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../data/resume.json';

const { name, github, linkedin, summary, skills, experience } = resume;
const jobTitle = "Data Analyst";
const projects = await getCollection('projects');

// Collect all skills and flatten them
const allSkills = Object.values(skills).flat() as string[];
---

<Layout title={name} path="/">
  <div class="homepage">

    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="hero-grid"></div>
      <div class="hero-content">
        <h1>{name}</h1>
        <p class="hero-title">{jobTitle}</p>
        <p class="hero-tagline">Turning raw data into decisions.</p>
        <p class="hero-stat">85% pipeline optimisation · 3+ yrs enterprise data · Telstra</p>
        <div class="hero-socials">
          <a href={`https://github.com/${github}`} target="_blank" rel="noopener" title="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href={`https://linkedin.com/in/${linkedin}`} target="_blank" rel="noopener" title="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a id="email-link" href="#">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
        <div class="scroll-indicator">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about">
      <div class="about-inner">
        <span class="about-label">About</span>
        <p class="about-text">{summary}</p>
      </div>
    </section>

    <!-- SKILLS CLOUD -->
    <section class="skills-section">
      <div class="skills-cloud">
        {allSkills.map(skill => {
          const randomOpacity = Math.random() * 0.6 + 0.4; // 0.4 to 1.0
          return (
            <span class="skill-tag" style={`--skill-opacity: ${randomOpacity}`}>
              {skill}
            </span>
          );
        })}
      </div>
    </section>

    <!-- SECTION CARDS -->
    <section class="cards-section">
      <div class="cards-grid">
        <a href="/projects" class="section-card">
          <div class="card-content">
            <h2>Projects →</h2>
            <p>{projects.length} projects built</p>
          </div>
        </a>
        <a href="/resume" class="section-card">
          <div class="card-content">
            <h2>Resume →</h2>
            <p>Experience & background</p>
          </div>
        </a>
      </div>
    </section>

  </div>
</Layout>

<style>
  .homepage {
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Hero ────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 75svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, var(--accent) 0.5px, transparent 0.5px);
    background-size: 40px 40px;
    background-position: var(--mx, 0) var(--my, 0);
    opacity: 0.08;
    transition: background-position 0.1s ease-out;
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 600px;
    padding: 2rem;
  }

  .hero-content h1 {
    font-size: clamp(2.2rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: 1.1rem;
    color: var(--tx-2);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: var(--tx-3);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero-stat {
    font-size: 0.85rem;
    color: var(--tx-3);
    font-weight: 500;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }

  .hero-socials {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .hero-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--tx-2);
    border: 1px solid var(--bd-subtle);
    border-radius: 8px;
    transition: color 0.15s, border-color 0.15s;
  }

  .hero-socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .scroll-indicator {
    display: flex;
    justify-content: center;
    color: var(--tx-muted);
    animation: bob 2s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ── About ───────────────────────────────────────── */
  .about {
    padding: 0 2rem 4rem;
    background: var(--bg-page);
  }

  .about-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-style: normal;
    font-weight: 400;
    line-height: 1.8;
    color: var(--tx-2);
    margin-bottom: 1.5rem;
  }

  .about-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
  }

  .about-inner {
    text-align: center;
  }

  .about-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    display: block;
    margin-bottom: 1rem;
  }

  /* ── Skills Cloud ────────────────────────────────── */
  .skills-section {
    padding: 3rem 2rem;
    border-top: 1px solid var(--bd-subtle);
    border-bottom: 1px solid var(--bd-subtle);
  }

  .skills-cloud {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    justify-content: center;
  }

  .skill-tag {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
    opacity: var(--skill-opacity, 0.7);
    transition: opacity 0.15s;
  }

  .skill-tag:hover {
    opacity: 1;
  }

  /* ── Section Cards ───────────────────────────────── */
  .cards-section {
    padding: 4rem 2rem;
  }

  .cards-grid {
    max-width: 760px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .section-card {
    padding: 2rem;
    border: 1px solid var(--bd-card);
    border-radius: 12px;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
    display: flex;
    align-items: center;
  }

  .section-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
  }

  .card-content {
    width: 100%;
  }

  .section-card h2 {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-family: 'Playfair Display', serif;
  }

  .section-card p {
    font-size: 0.85rem;
    color: var(--tx-3);
    line-height: 1.5;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 600px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .about {
      padding: 0 1.25rem 2rem;
    }

    .about-text {
      font-size: 0.95rem;
    }

    .skills-section {
      padding: 1.5rem 1.25rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }

    .cards-section {
      padding: 2rem 1.25rem;
    }

    .about-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('hero');
    const grid = hero?.querySelector('.hero-grid') as HTMLElement;

    if (grid) {
      document.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth) * 100;
        const y = (e.clientY / window.innerHeight) * 100;
        grid.style.setProperty('--mx', `${x}px`);
        grid.style.setProperty('--my', `${y}px`);
      });

      document.addEventListener('touchmove', (e) => {
        const touch = e.touches[0];
        const x = (touch.clientX / window.innerWidth) * 100;
        const y = (touch.clientY / window.innerHeight) * 100;
        grid.style.setProperty('--mx', `${x}px`);
        grid.style.setProperty('--my', `${y}px`);
      });
    }

    // Email obfuscation
    const u = 'darrellchew';
    const d = 'hotmail.com';
    const link = document.getElementById('email-link') as HTMLAnchorElement;
    if (link) link.href = 'mailto:' + u + '@' + d;
  });
</script>
