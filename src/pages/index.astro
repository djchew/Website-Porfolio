---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import resume from '../data/resume.json';

const { name, github, linkedin } = resume;
const jobTitle = "Data Analyst";
const projects = await getCollection('projects');
const featuredProject = projects.find(p => p.slug === 'melbourne-liveability');
const pageDescription = "Darrell Chew - Data Analyst and Analytics Engineer in Melbourne building data pipelines, dashboards, and analytics products.";
---

<Layout
  title={name}
  path="/"
  canonicalPath="/"
  description={pageDescription}
  ogType="website"
>
  <div class="homepage">

    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="hero-grid"></div>
      <div class="hero-split">

        <!-- LEFT: text -->
        <div class="hero-content">
          <p class="hero-greeting">Hi, I'm</p>
          <h1>{name}</h1>
          <p class="hero-title">{jobTitle} · Melbourne</p>
          <p class="hero-tagline">Turning raw data into decisions.</p>
          <span class="availability-chip">Open to new opportunities · Remote + Onsite</span>
          <div class="hero-ctas">
            <a class="cta-btn cta-primary" href="https://linkedin.com/in/darrell-chew" target="_blank" rel="noopener">Hire Me</a>
            <a class="cta-btn cta-secondary" href="/projects">View Work</a>
          </div>
          <div class="hero-socials">
            <a href={`https://github.com/${github}`} target="_blank" rel="noopener" title="GitHub" aria-label="GitHub profile">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href={`https://linkedin.com/in/${linkedin}`} target="_blank" rel="noopener" title="LinkedIn" aria-label="LinkedIn profile">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a id="email-link" href="#" aria-label="Send email">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </a>
          </div>
        </div>

        <!-- RIGHT: photo -->
        <div class="hero-photo">
          <div class="hero-photo-ring">
            <img src="/profile.jpg" alt="Darrell Chew" width="480" height="480" />
          </div>
        </div>

      </div>
      <div class="scroll-indicator">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </section>

    <!-- FEATURED PROJECT -->
    {featuredProject && (
      <section class="featured-project" data-animate>
        <div class="featured-content">
          <div class="featured-text">
            <span class="featured-label">Featured work</span>
            <h2 class="featured-title">{featuredProject.data.name}</h2>
            <p class="featured-description">{featuredProject.data.description}</p>
            {featuredProject.data.outcomes && featuredProject.data.outcomes[0] && (
              <p class="featured-outcome">
                <span class="outcome-check">✓</span>
                {featuredProject.data.outcomes[0]}
              </p>
            )}
            <div class="featured-tags">
              {featuredProject.data.tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
            </div>
            <a href={`/projects/${featuredProject.slug}`} class="featured-link">
              View project
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          </div>
          <div class="featured-image">
            {featuredProject.data.image && (
              <img src={featuredProject.data.image} alt={featuredProject.data.name} loading="lazy" decoding="async" width="600" height="400" />
            )}
          </div>
        </div>
      </section>
    )}

    <!-- NAV CIRCLES -->
    <section class="nav-circles">
      <a href="/about" class="nav-node">
        <div class="nav-circle">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </div>
        <span class="nav-label">About</span>
      </a>
      <a href="/projects" class="nav-node">
        <div class="nav-circle">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="2" x2="12" y2="22"></line>
            <path d="M17 5H9.5a1.5 1.5 0 0 0 0 3h5a1.5 1.5 0 0 1 0 3h-5a1.5 1.5 0 0 0 0 3H17"></path>
          </svg>
        </div>
        <span class="nav-label">Projects</span>
      </a>
      <a href="/resume" class="nav-node">
        <div class="nav-circle">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="13" x2="12" y2="17"></line>
            <line x1="10" y1="15" x2="14" y2="15"></line>
          </svg>
        </div>
        <span class="nav-label">Resume</span>
      </a>
    </section>

  </div>
</Layout>

<style>
  .homepage {
    background: var(--bg-page);
    color: var(--tx-1);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 60svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, var(--accent) 0.5px, transparent 0.5px);
    background-size: 40px 40px;
    background-position: var(--mx, 0) var(--my, 0);
    opacity: 0.08;
    transition: background-position 0.1s ease-out;
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }

  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    max-width: 1100px;
    width: 100%;
    padding: 4rem 2.5rem;
    position: relative;
    z-index: 10;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: left;
    padding: 0;
  }

  .hero-content h1 {
    font-size: clamp(2.2rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    background: var(--grad-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-title {
    font-size: 1.1rem;
    color: var(--tx-2);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: var(--tx-3);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .hero-greeting {
    font-size: 1.2rem;
    color: var(--tx-3);
    font-weight: 400;
    margin-bottom: 0.25rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .cta-btn {
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid var(--accent);
    transition: opacity 0.15s, background 0.15s, transform 0.15s;
    display: inline-block;
  }

  .cta-primary {
    background: var(--accent);
    color: #fff;
  }

  .cta-primary:hover {
    opacity: 0.88;
    transform: translateY(-2px);
  }

  .cta-secondary {
    background: transparent;
    color: var(--accent);
  }

  .cta-secondary:hover {
    background: var(--accent-bg);
    transform: translateY(-2px);
  }

  .availability-chip {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    background: var(--accent-bg);
    color: var(--accent);
    border: 1px solid var(--bd-accent);
    border-radius: 999px;
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }

  /* Photo column */
  .hero-photo {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-ring {
    width: min(420px, 100%);
    aspect-ratio: 1;
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--bd-card);
    box-shadow: 0 16px 48px var(--shadow);
  }

  .hero-photo-ring img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-socials {
    display: flex;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-bottom: 0;
  }

  .hero-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--tx-3);
    border: none;
    background: transparent;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s, transform 0.15s;
  }

  .hero-socials a:hover {
    color: var(--accent);
    background: var(--accent-bg);
    transform: translateY(-2px);
  }

  .scroll-indicator {
    display: none;
    justify-content: center;
    color: var(--tx-muted);
    animation: bob 2s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ── Featured Project ───────────────────────────── */
  .featured-project {
    background: var(--bg-page);
    padding: 3rem 2.5rem;
    margin: 2rem 0;
  }

  .featured-content {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .featured-label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tx-muted);
    margin-bottom: 0.75rem;
  }

  .featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--tx-1);
  }

  .featured-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--tx-2);
    margin-bottom: 1rem;
  }

  .featured-outcome {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--tx-2);
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .outcome-check {
    color: var(--accent);
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .featured-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .featured-tags .tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
  }

  .featured-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--bd-accent);
    border-radius: 8px;
    background: var(--accent-bg);
    transition: all 0.15s;
  }

  .featured-link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .featured-image {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--bd-card);
    box-shadow: 0 8px 24px var(--shadow);
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Nav Circles ────────────────────────────────────── */
  .nav-circles {
    display: flex;
    justify-content: center;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .nav-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .nav-circle {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: var(--nav-circle-bg);
    border: 2px solid var(--nav-circle-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-circle-icon);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nav-node:hover .nav-circle {
    transform: scale(1.08);
    box-shadow: 0 0 24px var(--nav-circle-glow);
  }

  .nav-label {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--tx-1);
    text-align: center;
    min-width: 100px;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 768px) {
    .featured-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .featured-image {
      order: -1;
    }

    .hero-split {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.25rem 3rem;
    }

    .hero-content {
      text-align: center;
    }

    .hero-ctas {
      justify-content: center;
    }

    .hero-socials {
      justify-content: center;
    }

    .hero-photo {
      order: -1;
    }

    .hero-photo-ring {
      width: min(280px, 80%);
    }
  }

  @media (max-width: 600px) {
    .featured-project {
      padding: 2rem 1.25rem;
    }

    .featured-title {
      font-size: 1.4rem;
    }

    .featured-description {
      font-size: 0.9rem;
    }

    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .nav-circles {
      padding: 1.5rem 1.25rem 0;
      gap: 2rem;
    }

    .nav-circle {
      width: 90px;
      height: 90px;
    }

    .nav-label {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  type GridState = { target: HTMLElement | null };

  const state = ((window as any).__heroGridState ??= { target: null }) as GridState;
  const hasBoundListeners = !!(window as any).__heroGridBound;

  if (!hasBoundListeners) {
    const handlePointerMove = (clientX: number, clientY: number) => {
      if (!state.target) return;
      const x = (clientX / window.innerWidth) * 100;
      const y = (clientY / window.innerHeight) * 100;
      state.target.style.setProperty('--mx', `${x}px`);
      state.target.style.setProperty('--my', `${y}px`);
    };

    document.addEventListener('mousemove', (e) => handlePointerMove(e.clientX, e.clientY), { passive: true });
    document.addEventListener('touchmove', (e) => {
      const touch = e.touches[0];
      if (!touch) return;
      handlePointerMove(touch.clientX, touch.clientY);
    }, { passive: true });

    (window as any).__heroGridBound = true;
  }

  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('hero');
    const grid = hero?.querySelector('.hero-grid') as HTMLElement | null;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    state.target = reducedMotion ? null : grid;

    // Email obfuscation
    const u = 'darrellchew';
    const d = 'hotmail.com';
    const link = document.getElementById('email-link') as HTMLAnchorElement;
    if (link) link.href = 'mailto:' + u + '@' + d;
  });
</script>
