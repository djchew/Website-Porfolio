---
import Layout from '../layouts/Layout.astro';
import resume from '../data/resume.json';

const { name, title: jobTitle, location, github, linkedin, summary, skills, experience, education, certifications, languages, volunteer, profile_picture } = resume;
const pageDescription = `${name} resume: ${jobTitle} in ${location}. Experience, skills, certifications, and project highlights.`;
---

<Layout
  title={`Resume - ${name}`}
  path="/resume"
  canonicalPath="/resume"
  description={pageDescription}
  ogType="profile"
>
  <div class="page">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      {profile_picture
        ? <img class="avatar" src={profile_picture} alt={name} loading="lazy" decoding="async" width="76" height="76" />
        : <div class="avatar">{name.split(' ').map(n => n[0]).join('')}</div>
      }

      <h1 class="name">{name}</h1>
      <p class="job-title">{jobTitle}</p>
      <p class="location">
        <svg width="11" height="14" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 0C3.24 0 1 2.24 1 5c0 3.75 5 11 5 11s5-7.25 5-11c0-2.76-2.24-5-5-5zm0 6.5C5.17 6.5 4.5 5.83 4.5 5S5.17 3.5 6 3.5 7.5 4.17 7.5 5 6.83 6.5 6 6.5z" fill="currentColor"/>
        </svg>
        {location}
      </p>

      <div class="social">
        <a href={`https://github.com/${github}`} target="_blank" rel="noopener" aria-label="GitHub profile">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href={`https://linkedin.com/in/${linkedin}`} target="_blank" rel="noopener" aria-label="LinkedIn profile">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a id="email-link" href="#" aria-label="Send email">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </a>
      </div>

      <div class="sidebar-section sidebar-about">
        <p class="label">About</p>
        <p class="about-text">{summary}</p>
      </div>

      <div class="sidebar-section">
        <a href="/Darrell Chew Resume.pdf" download class="download-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download Resume
        </a>
      </div>

      <div class="sidebar-section">
        <p class="label">Skills</p>
        {Object.entries(skills).map(([group, items]) => (
          <div class="skills-group">
            <p class="skills-group-label">{group}</p>
            <div class="tags">
              {(items as {name: string; level: string}[]).map(skill => (
                <span class={`tag tag--${skill.level}`}>{skill.level === 'expert' ? '⬤ ' : ''}{skill.name}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </aside>

    <!-- MAIN -->
    <section class="main" aria-label="Resume content">

      <!-- ABOUT (print only) -->
      <div class="print-about">
        <h2 class="section-title">About</h2>
        <p class="print-about-text">{summary}</p>
      </div>

      <!-- POSITIONING -->
      <section class="section positioning-section" data-animate>
        <h2 class="section-title">At a Glance</h2>
        <div class="positioning-grid">
          <div class="pos-item">
            <span class="pos-label">Ideal for</span>
            <span class="pos-value">Enterprise data teams with modern stack needs — Python, SQL, Power BI</span>
          </div>
          <div class="pos-item">
            <span class="pos-label">Strengths</span>
            <span class="pos-value">End-to-end pipeline design · SLA-driven delivery · Stakeholder translation</span>
          </div>
          <div class="pos-item">
            <span class="pos-label">Available</span>
            <span class="pos-value">Open to full-time and contract · Melbourne or remote</span>
          </div>
        </div>
      </section>

      <!-- EXPERIENCE -->
      <section class="section" data-animate>
        <h2 class="section-title">Experience</h2>
        {experience.map((exp, i) => (
          <div class="exp-item" data-animate style={`transition-delay:${i * 90}ms`}>
            <div class="exp-header">
              <span class="exp-title">{exp.title}</span>
              <span class="exp-date">{exp.start} – {exp.end}</span>
            </div>
            <p class="exp-company">{exp.company}</p>
            {exp.client && <p class="exp-client">{exp.client}</p>}
            <ul class="exp-points">
              {exp.points.map(point => <li>{point}</li>)}
            </ul>
          </div>
        ))}
      </section>

      <!-- EDUCATION + CERTIFICATIONS -->
      <div class="two-col">
        <section class="section" data-animate>
          <h2 class="section-title">Education</h2>
          {education.map(edu => (
            <div class="edu-item">
              <p class="edu-degree">{edu.degree}</p>
              <p class="edu-school">{edu.institution}</p>
              <p class="edu-date">{edu.start} – {edu.end}</p>
            </div>
          ))}
        </section>

        <section class="section" data-animate style="transition-delay:80ms">
          <h2 class="section-title">Certifications</h2>
          {certifications.map(cert => (
            <div class="cert-item">
              <div>
                <p class="cert-name">{cert.name}</p>
                <p class="cert-issuer">{cert.issuer}</p>
              </div>
              <span class="cert-date">{cert.date}</span>
            </div>
          ))}
        </section>
      </div>

      <!-- LANGUAGES + VOLUNTEER -->
      <div class="two-col">
        <section class="section" data-animate>
          <h2 class="section-title">Languages</h2>
          <div class="lang-grid">
            {languages.map(lang => (
              <div class="lang-item">
                <span class="lang-name">{lang.name}</span>
                <span class="lang-level">{lang.level}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="section" data-animate style="transition-delay:80ms">
          <h2 class="section-title">Volunteer</h2>
          {volunteer.map(vol => (
            <div class="vol-item">
              <p class="vol-role">{vol.role}</p>
              <p class="vol-org">{vol.organisation} · {vol.start} – {vol.end}</p>
              <p class="vol-desc">{vol.description}</p>
            </div>
          ))}
        </section>
      </div>

    </section>
  </div>
</Layout>

<style>
  /* ── Layout ──────────────────────────────────────── */
  .page {
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--tx-1);
  }

  /* ── Sidebar ─────────────────────────────────────── */
  .sidebar {
    background: var(--bg-page);
    border-right: none;
    padding: 2.5rem 1.75rem;
    position: sticky;
    top: 0;
    height: auto;
  }

  .avatar {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: var(--avatar-bg);
    color: var(--avatar-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
    object-fit: cover;
    box-shadow: 0 2px 8px rgba(30, 95, 142, 0.2);
  }

  .name {
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--tx-1);
    margin-bottom: 0.2rem;
  }

  .job-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--tx-2);
    margin-bottom: 0.4rem;
  }

  .location {
    font-size: 0.78rem;
    color: var(--tx-muted);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1.1rem;
  }

  /* Social links */
  .social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .social a {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--bd-accent);
    border-radius: 999px;
    background: var(--accent-bg);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .social a:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* Sidebar sections */
  .sidebar-section { margin-bottom: 1.5rem; }

  .download-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .download-btn:hover {
    background: var(--accent-hover, var(--accent));
    opacity: 0.9;
  }

  .label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-muted);
    margin-bottom: 0.75rem;
  }

  .about-text {
    font-size: 0.8rem;
    line-height: 1.75;
    color: var(--tx-2);
  }

  /* Skills */
  .skills-group { margin-bottom: 1.1rem; }

  .skills-group-label {
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--tx-muted);
    margin-bottom: 0.5rem;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-color);
  }

  .tag--expert {
    font-weight: 600;
  }

  /* ── Main ────────────────────────────────────────── */
  .main { padding: 2.5rem 2.75rem; }

  .section { margin-bottom: 2.3rem; }

  .section-title {
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tx-subtle);
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--bd-subtle);
    margin-bottom: 1.4rem;
  }

  /* Experience */
  .exp-item {
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--bd-subtle);
  }

  .exp-item:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.2rem;
  }

  .exp-title { font-size: 0.91rem; font-weight: 600; color: var(--tx-1); }

  .exp-date {
    font-size: 0.73rem;
    color: var(--tx-muted);
    white-space: nowrap;
    padding: 0.2rem 0.6rem;
    background: var(--pill-bg);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .exp-company { font-size: 0.81rem; font-weight: 500; color: var(--accent); margin-bottom: 0.15rem; }
  .exp-client  { font-size: 0.76rem; color: var(--tx-subtle); margin-bottom: 0.8rem; }

  .exp-points { list-style: none; padding: 0; margin-top: 0.6rem; }

  .exp-points li {
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--tx-2);
    padding-left: 1.1rem;
    position: relative;
    margin-bottom: 0.3rem;
  }

  .exp-points li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.7rem;
    top: 0.15rem;
  }

  /* Two-column layout */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

  /* Education */
  .edu-item { margin-bottom: 0.75rem; }
  .edu-degree { font-size: 0.875rem; font-weight: 600; color: var(--tx-1); }
  .edu-school { font-size: 0.8rem; color: var(--accent); font-weight: 500; margin-top: 0.1rem; }
  .edu-date   { font-size: 0.75rem; color: var(--tx-subtle); margin-top: 0.1rem; }

  /* Certifications */
  .cert-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--bd-subtle);
  }

  .cert-item:last-child { border-bottom: none; }
  .cert-name   { font-size: 0.825rem; font-weight: 500; color: var(--tx-1); }
  .cert-issuer { font-size: 0.72rem; color: var(--tx-subtle); margin-top: 0.1rem; }

  .cert-date {
    font-size: 0.72rem;
    color: var(--tx-muted);
    white-space: nowrap;
    padding: 0.15rem 0.5rem;
    background: var(--pill-bg);
    border-radius: 999px;
    flex-shrink: 0;
  }

  /* Languages */
  .lang-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1rem; }

  .lang-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--bd-subtle);
  }

  .lang-name  { font-size: 0.825rem; font-weight: 500; color: var(--tx-1); }
  .lang-level { font-size: 0.72rem; color: var(--tx-muted); padding: 0.15rem 0.5rem; background: var(--pill-bg); border-radius: 999px; }

  /* Volunteer */
  .vol-item { margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--bd-subtle); }
  .vol-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .vol-role { font-size: 0.875rem; font-weight: 600; color: var(--tx-1); }
  .vol-org  { font-size: 0.78rem; color: var(--accent); margin: 0.1rem 0 0.3rem; }
  .vol-desc { font-size: 0.8rem; color: var(--tx-2); line-height: 1.55; }

  /* ── Positioning Section ────────────────────────────── */
  .positioning-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pos-item {
    display: flex;
    gap: 1.2rem;
    align-items: baseline;
  }

  .pos-label {
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    flex-shrink: 0;
    min-width: 75px;
  }

  .pos-value {
    font-size: 0.86rem;
    color: var(--tx-2);
    line-height: 1.65;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; border-right: none; border-bottom: none; padding: 1.5rem 1.25rem; }
    .main { padding: 2rem 1.5rem; }
    .two-col { grid-template-columns: 1fr; }
    .exp-header { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
    .cert-item { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
    .lang-grid { grid-template-columns: 1fr; }
    .pos-item { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
    .pos-label { min-width: auto; }
  }

  @media (max-width: 600px) {
    .main { padding: 1.5rem 1.25rem; }
  }

  /* ── Print-only about block (hidden on screen) ───── */
  .print-about { display: none; }

  /* ── Print ───────────────────────────────────────── */
  @media print {
    :root {
      --bg-page: #fff;      --bg-sidebar: #fff;
      --bg-card: #fff;      --bd-main: #ddd;
      --bd-subtle: #e8e8e8; --tx-1: #000;
      --tx-2: #333;         --tx-3: #444;
      --tx-muted: #666;     --tx-subtle: #777;
      --accent: #1e5f8e;    --tag-bg: #e4eff8;
      --tag-color: #1e5f8e; --pill-bg: #e8e8e8;
      --icon-bg: #e4eff8;   --avatar-bg: #1e5f8e;
      --avatar-fg: #fff;
    }

    /* Layout */
    .page { grid-template-columns: 220px 1fr; }
    .sidebar {
      position: static;
      height: auto;
      overflow: visible;
      border-bottom: none;
      border-right: 1px solid #ddd;
      padding: 1.5rem 1.25rem;
    }
    .main { padding: 1.5rem 1.75rem; }

    /* Show about in main, hide from sidebar */
    .sidebar-about  { display: none; }
    .print-about    { display: block; margin-bottom: 1.75rem; }
    .print-about-text {
      font-size: 0.82rem;
      line-height: 1.7;
      color: #444;
      margin-top: 0.5rem;
    }

    /* Clean up for paper */
    a { color: inherit; text-decoration: none; }
    .social a { border: none; background: none; padding: 0; }
    .social { gap: 0.75rem; flex-direction: column; }
    .exp-item { break-inside: avoid; }
    .two-col  { break-inside: avoid; }

    @page { margin: 1.25cm 1.5cm; size: A4; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const u = 'darrellchew';
    const d = 'hotmail.com';
    const link = document.getElementById('email-link') as HTMLAnchorElement;
    if (link) link.href = 'mailto:' + u + '@' + d;
  });
</script>
